@startuml
title Use Cases Overview
left to right direction
skinparam packageStyle rectangle

actor "Visitor" as visitor
actor "Clinic User" as user

rectangle "Spring PetClinic" {

    package "General" {
        usecase "view-welcome-page\nUC-001" as UC001
        usecase "view-veterinarians\nUC-002" as UC002
    }

    package "Owner Management" {
        usecase "register-new-owner\nUC-003" as UC003
        usecase "find-owners-by-last-name\nUC-004" as UC004
        usecase "view-owner-details\nUC-005" as UC005
        usecase "update-owner\nUC-006" as UC006
    }

    package "Pet Management" {
        usecase "add-pet-to-owner\nUC-007" as UC007
        usecase "update-pet\nUC-008" as UC008
    }

    package "Visit Management" {
        usecase "book-visit-for-pet\nUC-009" as UC009
    }

    package "Error Handling" {
        usecase "view-application-error\nUC-010" as UC010
    }
}

' Visitor — anonymous, read-only access
visitor --> UC001
visitor --> UC002
visitor --> UC010

' Clinic User — inherits visitor access plus management use cases
user --> UC001
user --> UC002
user --> UC003
user --> UC004
user --> UC005
user --> UC006
user --> UC007
user --> UC008
user --> UC009
user --> UC010

' Relationships
UC007 ..> UC005 : <<extend>>
UC008 ..> UC005 : <<extend>>
UC009 ..> UC005 : <<extend>>
UC006 ..> UC005 : <<extend>>

@enduml
